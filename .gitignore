ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1256, Pipfile.lock should be committed unless the packaging/distribution
#   requires otherwise.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be committed unless the packaging/distribution
#   requires otherwise.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock should be committed unless the packaging/distribution
#   requires otherwise.
# pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

